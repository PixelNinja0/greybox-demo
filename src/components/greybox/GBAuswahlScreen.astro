---
import '../../styles/global.css';

interface Props {
  timerHref?: string;
  erinnerungHref?: string;
}

const { timerHref = '#', erinnerungHref = '#' } = Astro.props;
---

<div class="min-h-screen flex flex-col bg-(--gb-background) lg:bg-white">
  <main class="flex-1 flex flex-col items-center pt-16 px-8 pb-16 lg:pt-[51px] lg:px-12">
    <div class="flex flex-col items-center gap-12 w-full max-w-[326px] lg:max-w-none">
      <img src="/images/alarm-on.png" alt="Alarm" class="size-44" />

      <div class="flex flex-col items-center gap-12 w-full lg:gap-16">
        <div class="flex flex-col items-center gap-4 text-center w-full lg:max-w-[604px]">
          <h2
            class="text-(--gb-text) text-[1.375rem] font-semibold leading-[1.32] lg:text-[1.5625rem] lg:leading-[1.44]"
          >
            Willkommen bei Greybox<br />
            dein verlässlicher Begleiter für bewussten Fokus
          </h2>
          <p
            class="text-(--gb-text-light) text-[1.125rem] font-semibold leading-[1.39] lg:text-xl lg:leading-[1.4]"
          >
            Bitte wähle den Modus mit dem du starten willst
          </p>
        </div>

        <div class="flex flex-col gap-4 w-full lg:max-w-[530px]">
          <a
            href={timerHref}
            class="flex items-center justify-center h-[53px] w-full bg-(--gb-primary-600) rounded-(--gb-radius-lg) text-(--gb-background) font-medium text-base transition-colors hover:bg-(--gb-primary-700)"
          >
            Timer stellen
          </a>
          <a
            href={erinnerungHref}
            class="flex items-center justify-center h-[53px] w-full border-[1.5px] border-(--gb-border) rounded-(--gb-radius-lg) bg-transparent text-(--gb-text) font-medium text-base transition-colors hover:bg-black/5"
          >
            Erinnerung setzen
          </a>
        </div>
      </div>
    </div>
  </main>


</div>
