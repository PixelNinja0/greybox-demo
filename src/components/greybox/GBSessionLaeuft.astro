---
import '../../styles/global.css';

interface Props {
  initialMinutes?: number;
  initialSeconds?: number;
  abbrechenHref?: string;
  nextHref?: string;
}

const {
  initialMinutes = 5,
  initialSeconds = 30,
  abbrechenHref = '/',
  nextHref = '/session-ende',
} = Astro.props;
---

<!-- Penalty overlay (hidden by default, compact card) -->
<div
  id="penalty-overlay"
  class="hidden fixed top-[18%] left-1/2 -translate-x-1/2 z-50 w-[calc(100%-3rem)] max-w-sm bg-(--gb-surface) rounded-2xl shadow-2xl flex-col items-center gap-7 px-8 py-10 text-center"
>
  <h4 class="text-black font-semibold text-[1.125rem] leading-[1.39]">
    Du hast den Gegenstand von der Fläche entfernt
  </h4>
  <p class="text-(--gb-signal-orange) font-semibold text-[1.125rem] leading-[1.39] whitespace-nowrap">
    + 30 sek Strafzeit zusätzlich
  </p>
  <p class="text-black text-sm leading-[1.57]">
    Bitte leg den Gegenstand wieder auf die Fläche damit der timer weiter laufen kann
  </p>
</div>

<div class="min-h-screen flex flex-col bg-(--gb-background) lg:bg-white">
  <main class="flex-1 flex flex-col items-center gap-[52px] pt-16 px-8 pb-4 lg:pt-[125px] lg:gap-[27px]">

    <div class="flex flex-col gap-5 items-center text-center w-full lg:max-w-[1018px]">
      <h2 class="text-black text-[1.9375rem] font-semibold leading-tight lg:text-[2.375rem]">
        Bitte lege ein gewünschtes Objekt auf die Fläche unten
      </h2>
      <p class="text-black text-sm leading-[1.57] max-w-[354px] lg:max-w-[618px]">
        Nutze die Maus dazu. Drücke auf die Fläche unten und halte Sie gedrückt.
      </p>
    </div>

    <div class="flex flex-col items-center gap-4 w-full max-w-[325px]">
      <p class="text-(--gb-text-light) text-base leading-relaxed text-center">verbleibende Zeit:</p>
      <div
        class="flex items-end gap-15.75 border-[1.5px] border-(--gb-border) rounded-(--gb-radius-md) h-24.75 w-full pl-11 pr-13.5 pt-2.25 pb-2"
      >
        <div class="flex flex-col items-center gap-1 text-black text-center w-12.5">
          <span id="timer-minutes" class="text-[2.375rem] font-semibold leading-none">
            {String(initialMinutes).padStart(2, '0')}
          </span>
          <span class="text-xl font-semibold leading-7">min</span>
        </div>
        <div class="w-px h-20.5 bg-(--gb-border)"></div>
        <div class="flex flex-col items-center gap-1 text-black text-center w-12.75">
          <span id="timer-seconds" class="text-[2.375rem] font-semibold leading-none">
            {String(initialSeconds).padStart(2, '0')}
          </span>
          <span class="text-xl font-semibold leading-7">sek</span>
        </div>
      </div>
    </div>

    <div class="flex flex-col gap-4 w-full max-w-81.5 lg:max-w-[787px]">
      <p class="text-black text-xs leading-5 text-center">
        Bitte bleib mit deiner Maus auf der Fläche. Dies dient zur Simulation des Gegenstandes
      </p>
      <div
        id="hold-area"
        class="h-43.75 lg:h-65.5 w-full bg-(--gb-text-light) border-3 border-(--gb-signal-green) rounded-(--gb-radius-md) cursor-pointer select-none"
      ></div>
    </div>

    <a
      href={abbrechenHref}
      class="flex items-center justify-center h-13.25 w-full max-w-81.5 bg-(--gb-primary-600) rounded-(--gb-radius-lg) text-(--gb-background) font-medium text-base transition-colors hover:bg-(--gb-primary-700)"
    >
      Abbrechen
    </a>

  </main>


</div>

<script is:inline define:vars={{ initialMinutes, initialSeconds, nextHref }}>
  const PENALTY = 30;

  let total = initialMinutes * 60 + initialSeconds;
  let running = false;
  let ticker = null;
  let holdActive = false;

  const minEl = document.getElementById('timer-minutes');
  const sekEl = document.getElementById('timer-seconds');
  const holdArea = document.getElementById('hold-area');
  const overlay = document.getElementById('penalty-overlay');

  function render() {
    const m = Math.floor(total / 60);
    const s = total % 60;
    minEl.textContent = String(m).padStart(2, '0');
    sekEl.textContent = String(s).padStart(2, '0');
  }

  function startTimer() {
    if (running) return;
    running = true;
    ticker = setInterval(() => {
      total = Math.max(0, total - 1);
      render();
      if (total === 0) {
        clearInterval(ticker);
        running = false;
        window.location.href = nextHref;
      }
    }, 1000);
  }

  function pauseTimer() {
    if (!running) return;
    running = false;
    clearInterval(ticker);
  }

  function showOverlay() {
    overlay.classList.remove('hidden');
    overlay.classList.add('flex');
  }

  function hideOverlay() {
    overlay.classList.add('hidden');
    overlay.classList.remove('flex');
  }

  function onHoldStart() {
    holdActive = true;
    hideOverlay();
    startTimer();
  }

  function onHoldEnd() {
    if (!holdActive) return;
    holdActive = false;
    if (running) {
      pauseTimer();
      total += PENALTY;
      render();
      showOverlay();
    }
  }

  holdArea.addEventListener('mousedown', onHoldStart);
  holdArea.addEventListener('mouseup', onHoldEnd);
  holdArea.addEventListener('mouseleave', onHoldEnd);

  holdArea.addEventListener('touchstart', (e) => { e.preventDefault(); onHoldStart(); }, { passive: false });
  holdArea.addEventListener('touchend', onHoldEnd);
  holdArea.addEventListener('touchcancel', onHoldEnd);

  overlay.addEventListener('mousedown', () => hideOverlay());
  overlay.addEventListener('touchstart', (e) => { e.preventDefault(); hideOverlay(); }, { passive: false });
</script>
