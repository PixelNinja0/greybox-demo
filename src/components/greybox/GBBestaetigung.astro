---
import '../../styles/global.css';

interface Props {
  time?: string;
  zurückHref?: string;
  kalenderHref?: string;
}

const { time = '18:00', zurückHref = '/', kalenderHref = '#' } = Astro.props;
---

<div class="min-h-screen flex flex-col bg-(--gb-background) lg:bg-white">
  <main class="flex-1 flex flex-col items-center pt-16 px-8 pb-16 lg:pt-13.75">
    <div class="flex flex-col items-center gap-12 w-full lg:gap-16.25">

      <div class="flex flex-col items-center gap-8 w-full max-w-81.5 lg:max-w-155.25">
        <img
          src="/images/check-circle.png"
          alt="Erfolgreich"
          class="w-36.75 h-36.5 shrink-0"
        />
        <div class="flex flex-col items-center gap-5 text-center w-full">
          <h4
            class="text-black font-semibold text-[1.125rem] leading-[1.39] w-full lg:text-xl lg:leading-[1.4]"
          >
            Deine Erinnerung stellen war erfolgreich!
          </h4>
          <p class="text-(--gb-text-light) text-base leading-relaxed w-full">
            Du wirst um {time} Uhr erinnert.
          </p>
        </div>
      </div>

      <div class="flex flex-col items-center gap-4 w-full max-w-81.5 lg:max-w-124.75">
        <p class="text-black text-base leading-relaxed text-center w-full lg:text-(--gb-text-light)">
          Kehre zum Startbildschirm zurück
        </p>
        <a
          href={zurückHref}
          class="flex items-center justify-center h-13.25 w-full bg-(--gb-primary-600) rounded-(--gb-radius-lg) text-(--gb-background) font-medium text-base transition-colors hover:bg-(--gb-primary-700)"
        >
          Zurück zum start
        </a>
      </div>

      <div class="flex flex-col items-center gap-4 w-full max-w-79.75 lg:max-w-124.75 lg:gap-5">
        <p class="text-black text-xs leading-5 text-center w-full lg:text-(--gb-text)">
          Willst du deine Erinnerung noch zusätzlich in deinem Kalender speichern
        </p>
        <a
          href={kalenderHref}
          class="flex items-center justify-center h-12.25 w-63.5 text-(--gb-text) text-xl font-medium underline transition-opacity hover:opacity-70"
        >
          Im Kalender eintragen
        </a>
      </div>

    </div>
  </main>


</div>
